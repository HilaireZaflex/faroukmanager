# ── Application ──────────────────────────────────────────────────────────
APP_NAME=FaroukManager
DEBUG=true
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./farouk_manager.db

ADMIN_EMAIL=admin@faroukmanager.com
ADMIN_PASSWORD=Admin2026!
ADMIN_NAME=Administrateur

# ── Notifications - PROVIDERS EXTERNES ──────────────────────────────────
# Mode dry-run forcé (toutes les notifs sont simulées même si config présente)
NOTIFICATIONS_DRY_RUN=false

# Twilio (SMS)
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555555555

# WhatsApp Cloud API (Meta Business)
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# SMTP (Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@faroukmanager.com
SMTP_TLS=true
